#!/usr/bin/env bash
# shellcheck shell=bash
# shellcheck disable=SC2034
# shellcheck disable=SC2154
# Stats commands for ichrisbirch CLI
# Sourced by main CLI - do not run directly
# SC2034: Variables may appear unused but are used by sourcing script
# SC2154: Color variables are defined in main CLI before sourcing

STATS_DATA_DIR="$ICHRISBIRCH_HOME/stats/data"
STATS_EVENTS_FILE="$STATS_DATA_DIR/events/events.jsonl"

function stats-latest-file() {
  find -L "$STATS_DATA_DIR" -maxdepth 1 -name 'stats_*.json' -type f -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-
}

function stats-usage() {
  echo "${green}Stats Commands${reset}"
  echo ""
  echo "  ${blue}stats summary${reset}       Dashboard with code, tests, quality, and activity"
  echo "  ${blue}stats code${reset}          Lines of code by language (live from tokei)"
  echo "  ${blue}stats tests${reset}         Test results, coverage, and slowest tests"
  echo "  ${blue}stats quality${reset}       Linter issues over 24h/7d/30d/all time"
  echo "  ${blue}stats activity [n]${reset}  Commit activity graph (default: 7 days)"
  echo "  ${blue}stats events [n]${reset}    Recent pre-commit hook events (default: 20)"
  echo "  ${blue}stats trends${reset}        Velocity, code churn, and test suite trends"
  echo "  ${blue}stats churn [n|all]${reset} File churn analysis (default: 30 days, 'all' for entire history)"
  echo "  ${blue}stats snapshot${reset}      Regenerate stats snapshot from events.jsonl"
  echo ""
  echo "Data sources:"
  echo "  • Code stats: Live from tokei"
  echo "  • Test/coverage: From last snapshot (updated on commit)"
  echo "  • Quality: From events.jsonl (pre-commit hook results)"
  echo "  • Activity: From events.jsonl commit events"
}

function stats-summary() {
  cd "$ICHRISBIRCH_HOME" || exit
  local stats_file
  stats_file=$(stats-latest-file)


  echo "${green}Project Stats Summary${reset}"
  echo ""

  if [ -z "$stats_file" ] || [ ! -f "$stats_file" ]; then
    echo "${yellow}No stats snapshots found.${reset}"
    echo "Stats are collected automatically on each commit."
    return
  fi

  local collected_at
  collected_at=$(jq -r '.collected_at' "$stats_file" | cut -d'T' -f1)
  echo "Last collected: ${cyan}$collected_at${reset}"
  echo ""

  # Code stats (live from tokei) - show top 5 languages
  local tokei_json total_loc
  tokei_json=$(tokei . --compact --output json 2>/dev/null)
  total_loc=$(echo "$tokei_json" | jq -r '[to_entries[] | select(.value.code != null and .key != "Total") | [.value.code, .value.comments] | max] | add // 0')

  echo "${blue}Code${reset}"
  echo "$tokei_json" | jq -r 'to_entries | map(select(.value.code != null and .key != "Total")) | sort_by(-([.value.code, .value.comments] | max)) | .[0:5] | .[] | "\(.key)\t\([.value.code, .value.comments] | max)\t\(.value.reports | length)"' |
    while IFS=$'\t' read -r lang content files; do
      printf "  %-12s %'6d lines (%d files)\n" "$lang:" "$content" "$files"
    done
  printf "  ${cyan}%-12s %'6d lines${reset}\n" "Total:" "$total_loc"
  echo ""

  # Tests (combined Python + Frontend) - use 'active' (excludes skipped) with fallback to 'total'
  local py_active py_passed py_failed py_skipped coverage py_duration
  py_active=$(jq -r '.tests.active // .tests.total // 0' "$stats_file")
  py_passed=$(jq -r '.tests.passed // 0' "$stats_file")
  py_failed=$(jq -r '.tests.failed // 0' "$stats_file")
  py_skipped=$(jq -r '.tests.skipped // 0' "$stats_file")
  coverage=$(jq -r '.coverage.line_percent // 0' "$stats_file")
  py_duration=$(jq -r '.tests.duration_seconds // 0' "$stats_file" | cut -d'.' -f1)

  local fe_active fe_passed fe_failed fe_skipped fe_duration
  fe_active=$(jq -r '.frontend_tests.active // .frontend_tests.total // 0' "$stats_file")
  fe_passed=$(jq -r '.frontend_tests.passed // 0' "$stats_file")
  fe_failed=$(jq -r '.frontend_tests.failed // 0' "$stats_file")
  fe_skipped=$(jq -r '.frontend_tests.skipped // 0' "$stats_file")
  fe_duration=$(jq -r '.frontend_tests.duration_seconds // 0' "$stats_file" | cut -d'.' -f1)

  local e2e_active e2e_passed e2e_failed e2e_skipped e2e_duration
  e2e_active=$(jq -r '.e2e_tests.total // 0' "$stats_file")
  e2e_passed=$(jq -r '.e2e_tests.passed // 0' "$stats_file")
  e2e_failed=$(jq -r '.e2e_tests.failed // 0' "$stats_file")
  e2e_skipped=$(jq -r '.e2e_tests.skipped // 0' "$stats_file")
  e2e_duration=$(jq -r '.e2e_tests.duration_seconds // 0' "$stats_file" | cut -d'.' -f1)

  local all_active all_passed all_failed all_skipped all_duration pass_rate
  all_active=$((py_active + fe_active + e2e_active))
  all_passed=$((py_passed + fe_passed + e2e_passed))
  all_failed=$((py_failed + fe_failed + e2e_failed))
  all_skipped=$((py_skipped + fe_skipped + e2e_skipped))
  all_duration=$((py_duration + fe_duration + e2e_duration))
  pass_rate=0
  if [ "$all_active" -gt 0 ]; then
    pass_rate=$((all_passed * 100 / all_active))
  fi

  echo "${blue}Tests${reset}"
  if [ "$all_failed" -eq 0 ]; then
    printf "  Active:      %d tests (${green}%d%% pass${reset})\n" "$all_active" "$pass_rate"
  else
    printf "  Active:      %d tests (${red}%d failed${reset})\n" "$all_active" "$all_failed"
  fi
  printf "    Python:    %d\n" "$py_active"
  printf "    Frontend:  %d\n" "$fe_active"
  [ "$e2e_active" -gt 0 ] && printf "    E2E:       %d\n" "$e2e_active"
  [ "$all_skipped" -gt 0 ] && printf "  Skipped:     ${yellow}%d${reset}\n" "$all_skipped"
  printf "  Coverage:    ${cyan}%.1f%%${reset}\n" "$coverage"
  printf "  Duration:    %ds\n" "$all_duration"
  echo ""

  # Dependencies
  local deps_direct deps_total
  deps_direct=$(jq -r '.dependencies.direct // 0' "$stats_file")
  deps_total=$(jq -r '.dependencies.total // 0' "$stats_file")

  local npm_prod npm_dev npm_total
  npm_prod=$(jq -r '.npm_dependencies.production // 0' "$stats_file")
  npm_dev=$(jq -r '.npm_dependencies.dev // 0' "$stats_file")
  npm_total=$(jq -r '.npm_dependencies.total // 0' "$stats_file")

  echo "${blue}Dependencies${reset}"
  printf "  Python:      %d direct / %d total\n" "$deps_direct" "$deps_total"
  if [ "$npm_total" -gt 0 ]; then
    printf "  npm:         %d prod / %d dev / %d total\n" "$npm_prod" "$npm_dev" "$npm_total"
  fi
  echo ""

  # Commit activity
  if [ -f "$STATS_EVENTS_FILE" ]; then
    local total_commits today_commits week_commits week_pattern
    total_commits=$(grep -c '"type":"commit"' "$STATS_EVENTS_FILE" 2>/dev/null || echo 0)
    today_commits=$(grep '"type":"commit"' "$STATS_EVENTS_FILE" | grep -c "$(date +%Y-%m-%d)")
    week_pattern=$(for i in $(seq 0 6); do date -d "-${i} days" +%Y-%m-%d; done | paste -sd'|')
    week_commits=$(grep '"type":"commit"' "$STATS_EVENTS_FILE" | grep -cE "$week_pattern")

    echo "${blue}Activity${reset}"
    printf "  Today:       %d commits\n" "$today_commits"
    printf "  This week:   %d commits\n" "$week_commits"
    printf "  All time:    %d commits\n" "$total_commits"
  fi
}

function stats-snapshot() {
  cd "$ICHRISBIRCH_HOME" || exit
  uv run python -m stats.snapshot
}

function stats-code() {
  cd "$ICHRISBIRCH_HOME" || exit

  echo "${green}Code Statistics by Language${reset}"
  echo ""

  printf "${cyan}%-15s %10s %10s %8s${reset}\n" "Language" "Content" "Blanks" "Files"
  echo "---------------------------------------------------"

  local tokei_json
  tokei_json=$(tokei . --compact --output json 2>/dev/null)

  echo "$tokei_json" |
    jq -r 'to_entries | map(select(.value.code != null and .key != "Total")) | sort_by(-([.value.code, .value.comments] | max)) | .[] | [.key, ([.value.code, .value.comments] | max), .value.blanks, (.value.reports | length)] | @tsv' |
    while IFS=$'\t' read -r lang content blanks files; do
      printf "%-15s %'10d %'10d %8d\n" "$lang" "$content" "$blanks" "$files"
    done

  echo "---------------------------------------------------"
  local total_content total_blanks
  total_content=$(echo "$tokei_json" | jq -r '[to_entries[] | select(.value.code != null and .key != "Total") | [.value.code, .value.comments] | max] | add')
  total_blanks=$(echo "$tokei_json" | jq -r '[to_entries[] | select(.value.code != null and .key != "Total") | .value.blanks] | add')
  printf "${green}%-15s %'10d %'10d${reset}\n" "Total" "$total_content" "$total_blanks"
}

function stats-tests() {
  cd "$ICHRISBIRCH_HOME" || exit
  local stats_file
  stats_file=$(stats-latest-file)


  echo "${green}Test Statistics${reset}"
  echo ""

  if [ -z "$stats_file" ] || [ ! -f "$stats_file" ]; then
    echo "${yellow}No stats snapshots found.${reset}"
    return
  fi

  local py_active py_passed py_failed py_skipped py_errors py_duration coverage
  py_active=$(jq -r '.tests.active // .tests.total // 0' "$stats_file")
  py_passed=$(jq -r '.tests.passed // 0' "$stats_file")
  py_failed=$(jq -r '.tests.failed // 0' "$stats_file")
  py_skipped=$(jq -r '.tests.skipped // 0' "$stats_file")
  py_errors=$(jq -r '.tests.errors // 0' "$stats_file")
  py_duration=$(jq -r '.tests.duration_seconds // 0' "$stats_file")
  coverage=$(jq -r '.coverage.line_percent // 0' "$stats_file")

  local fe_active2 fe_passed2 fe_failed2 fe_skipped2 fe_duration2
  fe_active2=$(jq -r '.frontend_tests.active // .frontend_tests.total // 0' "$stats_file")
  fe_passed2=$(jq -r '.frontend_tests.passed // 0' "$stats_file")
  fe_failed2=$(jq -r '.frontend_tests.failed // 0' "$stats_file")
  fe_skipped2=$(jq -r '.frontend_tests.skipped // 0' "$stats_file")
  fe_duration2=$(jq -r '.frontend_tests.duration_seconds // 0' "$stats_file")

  local e2e_active2 e2e_passed2 e2e_failed2 e2e_skipped2 e2e_duration2
  e2e_active2=$(jq -r '.e2e_tests.total // 0' "$stats_file")
  e2e_passed2=$(jq -r '.e2e_tests.passed // 0' "$stats_file")
  e2e_failed2=$(jq -r '.e2e_tests.failed // 0' "$stats_file")
  e2e_skipped2=$(jq -r '.e2e_tests.skipped // 0' "$stats_file")
  e2e_duration2=$(jq -r '.e2e_tests.duration_seconds // 0' "$stats_file")

  local all_active all_passed all_failed all_skipped all_duration
  all_active=$((py_active + fe_active2 + e2e_active2))
  all_passed=$((py_passed + fe_passed2 + e2e_passed2))
  all_failed=$((py_failed + fe_failed2 + e2e_failed2))
  all_skipped=$((py_skipped + fe_skipped2 + e2e_skipped2))
  all_duration=$(echo "$py_duration + $fe_duration2 + $e2e_duration2" | bc)

  echo "${blue}Current Results${reset}"
  printf "  Active:    %d\n" "$all_active"
  printf "    Python:    %d\n" "$py_active"
  printf "    Frontend:  %d\n" "$fe_active2"
  [ "$e2e_active2" -gt 0 ] && printf "    E2E:       %d\n" "$e2e_active2"
  printf "  Passed:    ${green}%d${reset}\n" "$all_passed"
  [ "$all_failed" -gt 0 ] && printf "  Failed:    ${red}%d${reset}\n" "$all_failed"
  [ "$all_skipped" -gt 0 ] && printf "  Skipped:   ${yellow}%d${reset}\n" "$all_skipped"
  [ "$py_errors" -gt 0 ] && printf "  Errors:    ${red}%d${reset}\n" "$py_errors"
  printf "  Duration:  %.0fs\n" "$all_duration"
  printf "  Coverage:  %.1f%%\n" "$coverage"
  echo ""

  # Test Suite Trends from events.jsonl
  if [ -f "$STATS_EVENTS_FILE" ]; then
    echo "${blue}Test Suite Trends (by day)${reset}"
    printf "${cyan}%-12s %6s %8s %6s %8s${reset}\n" "Date" "Tests" "Duration" "Failed" "Pass %"
    echo "----------------------------------------------"
    # Combine pytest and vitest events by date
    local pytest_by_day vitest_by_day
    pytest_by_day=$(grep '"type":"collect.pytest"' "$STATS_EVENTS_FILE" | jq -s '
      group_by(.timestamp[0:10]) |
      map({
        date: .[0].timestamp[0:10],
        avg_tests: ([.[].summary | (.total - (.skipped // 0))] | add / length | floor),
        avg_duration: ([.[].duration_seconds] | add / length | floor),
        total_failed: ([.[].summary.failed] | add),
        avg_passed: ([.[].summary.passed] | add / length | floor)
      })' 2>/dev/null)
    vitest_by_day=$(grep '"type":"collect.vitest"' "$STATS_EVENTS_FILE" | jq -s '
      group_by(.timestamp[0:10]) |
      map({
        date: .[0].timestamp[0:10],
        avg_tests: ([.[].summary | (.total - (.skipped // 0))] | add / length | floor),
        avg_duration: ([.[].duration_seconds] | add / length | floor),
        total_failed: ([.[].summary.failed] | add),
        avg_passed: ([.[].summary.passed] | add / length | floor)
      })' 2>/dev/null)
    # Merge by date: add vitest totals to pytest totals
    echo "$pytest_by_day" | jq -r --argjson vitest "$vitest_by_day" '
      . as $pytest |
      ($vitest | map({(.date): .}) | add // {}) as $vmap |
      $pytest | map(
        ($vmap[.date] // {avg_tests: 0, avg_duration: 0, total_failed: 0, avg_passed: 0}) as $v |
        {
          date: .date,
          tests: (.avg_tests + $v.avg_tests),
          duration: (.avg_duration + $v.avg_duration),
          failed: (.total_failed + $v.total_failed),
          passed: (.avg_passed + $v.avg_passed)
        }
      ) |
      .[-7:] | reverse | .[] |
      "\(.date)\t\(.tests)\t\(.duration)s\t\(.failed)\t\(((.passed * 100) / .tests) | floor)%"
    ' 2>/dev/null | while IFS=$'\t' read -r date tests dur failed pct; do
      if [ "$failed" -gt 0 ]; then
        printf "%-12s %6s %8s ${red}%6s${reset} %8s\n" "$date" "$tests" "$dur" "$failed" "$pct"
      else
        printf "%-12s %6s %8s ${green}%6s${reset} %8s\n" "$date" "$tests" "$dur" "$failed" "$pct"
      fi
    done
    echo ""

    # Test Suite History (last 25 runs) - vertical bar chart
    echo "${blue}Test Suite History (last 25 runs)${reset}"

    local test_history max_dur=1 max_tests=1
    # Combine pytest + vitest events by timestamp proximity, filter out bad data (runs with 0 tests)
    local pytest_hist vitest_hist
    pytest_hist=$(grep '"type":"collect.pytest"' "$STATS_EVENTS_FILE" | jq -s '[.[] | select(.summary.total > 0)] | .[] | {ts: .timestamp[0:19], dur: (.duration_seconds | floor), tests: (.summary.total - (.summary.skipped // 0))}' | jq -s '.' 2>/dev/null)
    vitest_hist=$(grep '"type":"collect.vitest"' "$STATS_EVENTS_FILE" | jq -s '.[] | {ts: .timestamp[0:19], dur: (.duration_seconds | floor), tests: (.summary.total - (.summary.skipped // 0))}' | jq -s '.' 2>/dev/null)
    # Merge: for each pytest run, find vitest event with closest timestamp (within 60s) and add counts
    test_history=$(echo "$pytest_hist" | jq -r --argjson vitest "$vitest_hist" '
      . as $pytest |
      ($vitest // []) as $vt |
      [$pytest[] |
        . as $p |
        ($vt | map(select(
          (.ts[0:10] == $p.ts[0:10])
        )) | if length > 0 then .[0] else {dur: 0, tests: 0} end) as $v |
        {dur: ($p.dur + $v.dur), tests: ($p.tests + $v.tests)}
      ] | .[-25:]' 2>/dev/null)
    max_dur=$(echo "$test_history" | jq '[.[].dur] | max // 1')
    max_tests=$(echo "$test_history" | jq '[.[].tests] | max // 1')

    # Legend with max values
    echo "  ${yellow}██${reset} Duration (max ${max_dur}s)   ${green}██${reset} Tests (max ${max_tests})"
    echo ""

    # Store data in arrays for vertical rendering
    local -a durs tests_arr dur_heights test_heights
    local i=0
    while IFS=$'\t' read -r dur tests; do
      durs[i]=$dur
      tests_arr[i]=$tests
      dur_heights[i]=$(( (dur * 8) / max_dur ))
      test_heights[i]=$(( (tests * 8) / max_tests ))
      ((i++))
    done < <(echo "$test_history" | jq -r '.[] | "\(.dur)\t\(.tests)"')

    local num_runs=$i

    # Draw vertical bars (8 rows) - 5 chars per run: ████ (yellow+green+space)
    for row in $(seq 8 -1 1); do
      printf "  "
      for ((r=0; r<num_runs; r++)); do
        if [ "${dur_heights[r]}" -ge "$row" ]; then
          printf "%s" "${yellow}██${reset}"
        else
          printf "  "
        fi
        if [ "${test_heights[r]}" -ge "$row" ]; then
          printf "%s" "${green}██${reset}"
        else
          printf "  "
        fi
        printf " "
      done
      printf "\n"
    done

    # Duration labels (yellow, left-aligned in 5-char slot)
    printf "  "
    for ((r=0; r<num_runs; r++)); do
      printf "${yellow}%-4d${reset} " "${durs[r]}"
    done
    printf "\n"
    # Test count labels (green, right-aligned in 5-char slot)
    printf "  "
    for ((r=0; r<num_runs; r++)); do
      printf "${green}%4d${reset} " "${tests_arr[r]}"
    done
    printf "\n"
    echo ""

    # Slowest Test Files
    echo "${blue}Slowest Test Files${reset}"
    local latest_pytest
    latest_pytest=$(grep '"type":"collect.pytest"' "$STATS_EVENTS_FILE" | tail -1)
    echo "$latest_pytest" | jq -r '
      [.tests[] | {
        path: (
          (.nodeid | split("::")[0]) as $file |
          $file | split("/") |
          if .[1] == "ichrisbirch" and (.[2] == "api" or .[2] == "app" or .[2] == "frontend") then
            . | join("/")
          else
            .[0:3] | join("/")
          end
        ),
        duration: ((.setup.duration // 0) + (.call.duration // 0) + (.teardown.duration // 0))
      }] |
      group_by(.path) |
      map({path: .[0].path, total: ([.[].duration] | add), count: length}) |
      sort_by(-.total) |
      ([.[].total] | add) as $grand_total |
      map(select(.total > ($grand_total * 0.008))) |
      .[0:12] |
      (.[0].total) as $max |
      .[] |
      {path: .path, total: .total, count: .count, bar_len: ((.total / $max * 30) | floor)}
    ' 2>/dev/null | jq -rs '.[] | "\(.path)\t\(.total)\t\(.count)\t\(.bar_len)"' | while IFS=$'\t' read -r path total count bar_len; do
      local bar=""
      for ((i=0; i<bar_len; i++)); do bar="${bar}█"; done
      # Shorten path for display
      local short_path="${path#tests/ichrisbirch/}"
      short_path="${short_path#tests/}"
      printf "  %-38s %5.1fs (%3d) %s\n" "${short_path:0:38}" "$total" "$count" "$bar"
    done
    echo ""

    # Tests per Directory
    echo "${blue}Tests per Directory${reset}"
    echo "$latest_pytest" | jq -r '
      [.tests[] | .nodeid | split("/") |
        if .[1] == "ichrisbirch" and (.[2] == "api" or .[2] == "app") then
          .[0:4] | join("/")
        else
          .[0:3] | join("/")
        end
      ] |
      group_by(.) |
      map({dir: .[0], count: length}) |
      sort_by(-.count) |
      .[0:10] |
      .[] |
      "\(.dir)\t\(.count)"
    ' 2>/dev/null | while IFS=$'\t' read -r dir count; do
      printf "  %-40s %4d tests\n" "${dir:0:40}" "$count"
    done
    echo ""

    # Flaky Tests (tests that sometimes fail)
    echo "${blue}Flaky Tests (failed in some runs)${reset}"
    local flaky_tests
    flaky_tests=$(grep '"type":"collect.pytest"' "$STATS_EVENTS_FILE" | jq -s '
      [.[].tests[] | select(.outcome == "failed")] |
      group_by(.nodeid) |
      map({test: .[0].nodeid, failures: length}) |
      sort_by(-.failures) |
      .[0:5]
    ' 2>/dev/null)
    if [ "$(echo "$flaky_tests" | jq 'length')" -gt 0 ]; then
      echo "$flaky_tests" | jq -r '.[] | "  \(.failures)x  \(.test | split("::") | .[-1])"'
    else
      echo "  ${green}No flaky tests detected${reset}"
    fi
    echo ""
  fi

  echo "${blue}Slowest Python Tests (latest run)${reset}"
  jq -r '.tests.slowest[:8] | .[] | "  " + (.duration | tostring | .[0:5]) + "s  " + .name' "$stats_file" 2>/dev/null |
    sed 's|tests/ichrisbirch/||g' | sed 's|::test_|: |g'
  echo ""

  # Frontend Tests (Vitest)
  local fe_active fe_passed fe_failed fe_skipped fe_duration
  fe_active=$(jq -r '.frontend_tests.active // .frontend_tests.total // 0' "$stats_file")
  fe_passed=$(jq -r '.frontend_tests.passed // 0' "$stats_file")
  fe_failed=$(jq -r '.frontend_tests.failed // 0' "$stats_file")
  fe_skipped=$(jq -r '.frontend_tests.skipped // 0' "$stats_file")
  fe_duration=$(jq -r '.frontend_tests.duration_seconds // 0' "$stats_file")

  echo "${blue}Frontend Test Details (Vitest)${reset}"
  if [ "$fe_active" -eq 0 ] && [ "$fe_skipped" -eq 0 ]; then
    printf "  %sNo vitest results collected%s\n" "$gray" "$reset"
  else
    printf "  Active:    %d\n" "$fe_active"
    printf "  Passed:    ${green}%d${reset}\n" "$fe_passed"
    [ "$fe_failed" -gt 0 ] && printf "  Failed:    ${red}%d${reset}\n" "$fe_failed"
    [ "$fe_skipped" -gt 0 ] && printf "  Skipped:   ${yellow}%d${reset}\n" "$fe_skipped"
    printf "  Duration:  %.1fs\n" "$fe_duration"
    echo ""

    echo "${blue}Slowest Frontend Tests${reset}"
    jq -r '.frontend_tests.slowest[:8] | .[] | (.name | sub(".*/frontend/src/"; "") | sub("/__tests__"; "") | sub("\\.test\\.ts::"; ": ")) as $short | "  " + (.duration | tostring | .[0:5]) + "s  " + $short' "$stats_file" 2>/dev/null
  fi
  echo ""

  # E2E Tests (Playwright)
  local e2e_total e2e_passed3 e2e_failed3 e2e_skipped3 e2e_duration3
  e2e_total=$(jq -r '.e2e_tests.total // 0' "$stats_file")
  e2e_passed3=$(jq -r '.e2e_tests.passed // 0' "$stats_file")
  e2e_failed3=$(jq -r '.e2e_tests.failed // 0' "$stats_file")
  e2e_skipped3=$(jq -r '.e2e_tests.skipped // 0' "$stats_file")
  e2e_duration3=$(jq -r '.e2e_tests.duration_seconds // 0' "$stats_file")

  echo "${blue}E2E Test Details (Playwright)${reset}"
  if [ "$e2e_total" -eq 0 ]; then
    printf "  %sNo E2E results collected%s\n" "$gray" "$reset"
  else
    printf "  Total:     %d\n" "$e2e_total"
    printf "  Passed:    ${green}%d${reset}\n" "$e2e_passed3"
    [ "$e2e_failed3" -gt 0 ] && printf "  Failed:    ${red}%d${reset}\n" "$e2e_failed3"
    [ "$e2e_skipped3" -gt 0 ] && printf "  Skipped:   ${yellow}%d${reset}\n" "$e2e_skipped3"
    printf "  Duration:  %.1fs\n" "$e2e_duration3"
    echo ""

    echo "${blue}Slowest E2E Tests${reset}"
    jq -r '.e2e_tests.slowest[:8] | .[] | "  " + (.duration | tostring | .[0:5]) + "s  " + .name' "$stats_file" 2>/dev/null
  fi
}

function stats-quality() {
  cd "$ICHRISBIRCH_HOME" || exit


  echo "${green}Code Quality - Pre-commit Hook Results${reset}"
  echo ""

  if [ ! -f "$STATS_EVENTS_FILE" ]; then
    echo "${yellow}No events file found.${reset}"
    return
  fi

  local today
  today=$(date +%Y-%m-%d)

  printf "${cyan}%-18s %6s %6s %6s %6s${reset}\n" "Tool" "24h" "7d" "30d" "All"
  echo "----------------------------------------------------"

  local tools=(
    # Python
    "ruff-check" "ruff-format" "mypy" "bandit" "codespell" "refurb" "pyupgrade"
    # Shell / Docker / Terraform
    "shellcheck" "hadolint" "docker-compose-validate"
    "terraform-validate" "terraform-tflint" "terraform-fmt" "terraform-docs"
    # File format / fixers
    "check-yaml" "check-toml" "check-json" "detect-private-key"
    "end-of-file-fixer" "trailing-whitespace"
    # Frontend
    "sass" "vue-eslint" "vue-prettier" "vue-typecheck"
    # Docs / validation
    "markdownlint" "djlint" "actionlint"
    "validate-html" "validate-markdown-links"
    # Project
    "code-sync" "generate-fixture-diagrams" "uv-lock"
  )

  get_issue_field() {
    case "$1" in
    mypy|vue-typecheck) echo ".errors" ;;
    ruff-format|vue-prettier|terraform-fmt) echo ".files_reformatted" ;;
    pyupgrade) echo ".rewritten_files" ;;
    shellcheck) echo ".comments" ;;
    vue-eslint) echo ".messages" ;;
    end-of-file-fixer|trailing-whitespace) echo ".fixed_files" ;;
    validate-markdown-links) echo ".broken_links" ;;
    *) echo ".issues" ;;
    esac
  }

  for tool in "${tools[@]}"; do
    local issues_today issues_7d issues_30d issues_all field
    field=$(get_issue_field "$tool")

    issues_today=$(grep "\"type\":\"hook.$tool\"" "$STATS_EVENTS_FILE" | grep "$today" | jq -s "[.[]$field | length] | add // 0")
    issues_7d=$(grep "\"type\":\"hook.$tool\"" "$STATS_EVENTS_FILE" | grep -E "$(for i in $(seq 0 6); do date -d "-${i} days" +%Y-%m-%d; done | paste -sd'|')" | jq -s "[.[]$field | length] | add // 0")
    issues_30d=$(grep "\"type\":\"hook.$tool\"" "$STATS_EVENTS_FILE" | grep -E "$(for i in $(seq 0 29); do date -d "-${i} days" +%Y-%m-%d; done | paste -sd'|')" | jq -s "[.[]$field | length] | add // 0")
    issues_all=$(grep "\"type\":\"hook.$tool\"" "$STATS_EVENTS_FILE" | jq -s "[.[]$field | length] | add // 0")

    local c_today c_7d c_30d c_all
    if [ "$issues_today" -eq 0 ]; then c_today="${gray}     0${reset}"; else c_today="${yellow}$(printf '%6d' "$issues_today")${reset}"; fi
    if [ "$issues_7d" -eq 0 ]; then c_7d="${gray}     0${reset}"; else c_7d="${yellow}$(printf '%6d' "$issues_7d")${reset}"; fi
    if [ "$issues_30d" -eq 0 ]; then c_30d="${gray}     0${reset}"; else c_30d="${yellow}$(printf '%6d' "$issues_30d")${reset}"; fi
    if [ "$issues_all" -eq 0 ]; then c_all="${gray}     0${reset}"; else c_all="$(printf '%6d' "$issues_all")"; fi

    printf "%-18s %s %s %s %s\n" "$tool" "$c_today" "$c_7d" "$c_30d" "$c_all"
  done

  echo ""

  echo "${blue}Hook Runs${reset}"
  printf "${cyan}%-10s %7s %7s %12s${reset}\n" "Period" "Runs" "Fail%" "vs Today"
  echo "----------------------------------------"

  get_date_pattern() {
    local days=$1
    for i in $(seq 0 $((days - 1))); do
      date -d "-${i} days" +%Y-%m-%d
    done | paste -sd'|'
  }

  local periods=("1" "7" "14" "30" "60" "90")
  local labels=("Today" "Last 7d" "Last 14d" "Last 30d" "Last 60d" "Last 90d")
  local today_pct=""

  for i in "${!periods[@]}"; do
    local days=${periods[$i]}
    local label=${labels[$i]}
    local pattern runs failed pct

    if [ "$days" -eq 1 ]; then
      pattern="$today"
    else
      pattern=$(get_date_pattern "$days")
    fi

    runs=$(grep '"type":"hook\.' "$STATS_EVENTS_FILE" | grep -cE "$pattern" || echo 0)
    failed=$(grep '"type":"hook\.' "$STATS_EVENTS_FILE" | grep -E "$pattern" | grep -c '"status":"failed"' || echo 0)

    if [ "$runs" -gt 0 ]; then
      pct=$(echo "scale=1; $failed * 100 / $runs" | bc)
    else
      pct="0"
    fi

    if [ "$days" -eq 1 ]; then
      today_pct="$pct"
      printf "%-10s %7d %6s%%\n" "$label" "$runs" "$pct"
    else
      local change_str=""
      if [ "$runs" -gt 0 ] && [ "$(echo "$today_pct > 0" | bc)" -eq 1 ]; then
        local change
        change=$(echo "scale=1; ($pct - $today_pct) * 100 / $today_pct" | bc)
        if [ "$(echo "$change > 0" | bc)" -eq 1 ]; then
          change_str="${red}$(printf '↑%6.1f%%' "$change")${reset}"
        elif [ "$(echo "$change < 0" | bc)" -eq 1 ]; then
          change_str="${green}$(printf '↓%6.1f%%' "${change#-}")${reset}"
        else
          change_str="${gray}     --  ${reset}"
        fi
      elif [ "$(echo "$pct > 0" | bc)" -eq 1 ]; then
        change_str="${red}$(printf '↑%6.1f%%' "$pct")${reset}"
      else
        change_str="${gray}     --  ${reset}"
      fi
      printf "%-10s %7d %6s%% %b\n" "$label" "$runs" "$pct" "$change_str"
    fi
  done

  echo ""
  echo "${gray}Note: Issues shown are from all pre-commit runs (including failed commits)${reset}"
}

function stats-activity() {
  cd "$ICHRISBIRCH_HOME" || exit
  local days="${1:-7}"


  echo "${green}Commit Activity (last $days days)${reset}"
  echo ""

  if [ ! -f "$STATS_EVENTS_FILE" ]; then
    echo "${yellow}No events file found.${reset}"
    return
  fi

  for i in $(seq 0 $((days - 1))); do
    local date_str day_name count bar
    date_str=$(date -d "-${i} days" +%Y-%m-%d)
    day_name=$(date -d "-${i} days" +%a)
    count=$(grep '"type":"commit"' "$STATS_EVENTS_FILE" | grep -c "$date_str")

    bar=""
    for ((j = 0; j < count && j < 20; j++)); do
      bar="${bar}#"
    done
    [ "$count" -gt 20 ] && bar="${bar}+"

    if [ "$i" -eq 0 ]; then
      printf "${cyan}%-10s${reset} %-3s  ${green}%-20s${reset} %d\n" "$date_str" "$day_name" "$bar" "$count"
    else
      printf "%-10s %-3s  ${green}%-20s${reset} %d\n" "$date_str" "$day_name" "$bar" "$count"
    fi
  done

  echo ""
  local total_week
  total_week=$(grep -c '"type":"commit"' "$STATS_EVENTS_FILE")
  echo "Total recorded commits: $total_week"
}

function stats-events() {
  cd "$ICHRISBIRCH_HOME" || exit
  local count="${1:-20}"


  echo "${green}Recent Events (last $count)${reset}"
  echo ""

  if [ -f "$STATS_EVENTS_FILE" ]; then
    tail -n "$count" "$STATS_EVENTS_FILE" | jq -r '
      def info:
        if .type == "commit" then [.short_hash, ""]
        elif .type == "collect.tokei" then [(.total_files | tostring), "files"]
        elif .type == "collect.pytest" then [((.summary.total - (.summary.skipped // 0)) | tostring), "tests"]
        elif .type == "collect.coverage" then ["\(.summary.percent_covered | floor)%", "coverage"]
        elif .type == "collect.docker" then [(.containers | length | tostring), "containers"]
        elif .type == "collect.dependencies" then [(.total_count | tostring), "pkgs"]
        elif .type == "collect.files" then [(.total_files | tostring), "files"]
        elif .type == "collect.radon" then [(.avg_complexity | floor | tostring), "avg_complexity"]
        elif .type == "collect.vitest" then [((.summary.total - (.summary.skipped // 0)) | tostring), "fe_tests"]
        elif .type == "collect.npm_dependencies" then [(.total_count | tostring), "npm_pkgs"]
        elif .status then [.status, ""]
        else ["-", ""]
        end;
      "\(.type)\t\(.timestamp[11:19])\t\(info[0])\t\(info[1])"
    ' | while IFS=$'\t' read -r type time value label; do
      printf "%-30s  %s  %6s  %s\n" "$type" "$time" "$value" "$label"
    done
  else
    echo "${yellow}No events file found.${reset}"
  fi
}

function stats-churn() {
  cd "$ICHRISBIRCH_HOME" || exit
  local arg="${1:-30}"

  if [ "$arg" = "all" ]; then
    stats-churn-all
    return
  fi

  local days="$arg"
  echo "${green}Code Churn Analysis (last $days days)${reset}"
  echo ""

  echo "${blue}Most Modified Files${reset}"
  git log --since="$days days ago" --name-only --pretty=format: 2>/dev/null |
    grep -v '^$' | grep -v '\.lock$' | sort | uniq -c | sort -rn | head -10 |
    while read -r count file; do
      printf "  %4d changes  %s\n" "$count" "$file"
    done
  echo ""

  echo "${blue}Most Lines Changed${reset}"
  git log --since="$days days ago" --numstat --pretty=format: 2>/dev/null |
    awk 'NF==3 && $1 != "-" && $3 !~ /\.lock$/ {adds[$3]+=$1; dels[$3]+=$2} END {for(f in adds) print adds[f]+dels[f], adds[f], dels[f], f}' |
    sort -rn | head -10 |
    while read -r total added deleted file; do
      printf "  %5d lines  ${green}+%-5d${reset} ${red}-%-5d${reset}  %s\n" "$total" "$added" "$deleted" "$file"
    done
  echo ""

  echo "${blue}Recently Created Files${reset}"
  git log --since="$days days ago" --diff-filter=A --name-only --pretty=format: 2>/dev/null |
    grep -v '^$' | grep -v '\.lock$' | sort -u | tail -10 |
    while read -r file; do
      [ -f "$file" ] && printf "  ${green}+${reset} %s\n" "$file"
    done
  echo ""

  echo "${blue}Recently Deleted Files${reset}"
  git log --since="$days days ago" --diff-filter=D --name-only --pretty=format: 2>/dev/null |
    grep -v '^$' | grep -v '\.lock$' | sort -u | tail -10 |
    while read -r file; do
      printf "  ${red}-${reset} %s\n" "$file"
    done
  echo ""

  echo "${blue}Churn by Directory${reset}"
  git log --since="$days days ago" --name-only --pretty=format: 2>/dev/null |
    grep -v '^$' | grep '/' |
    awk -F'/' 'NF>=3 {print $1"/"$2}' |
    sort | uniq -c | sort -rn | head -10 |
    while read -r count dir; do
      printf "  %4d changes  %s/\n" "$count" "$dir"
    done
}

