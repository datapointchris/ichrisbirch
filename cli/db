#!/usr/bin/env bash
# shellcheck shell=bash
# shellcheck disable=SC2034
# shellcheck disable=SC2154
# Database commands for ichrisbirch CLI
# Sourced by main CLI - do not run directly
# SC2034: Variables may appear unused but are used by sourcing script
# SC2154: Color variables are defined in main CLI before sourcing

function db-env-vars() {
  # Map environment name to host-accessible connection params.
  # .env has POSTGRES_HOST=postgres (Docker-internal), which doesn't resolve
  # from the host. python-dotenv won't override existing env vars, so exporting
  # here takes precedence over .env values.
  local env="$1"
  case "$env" in
  development)
    export ENVIRONMENT=development
    export POSTGRES_HOST=localhost
    export POSTGRES_PORT=5432
    ;;
  testing)
    export ENVIRONMENT=testing
    export POSTGRES_HOST=localhost
    export POSTGRES_PORT=5434
    ;;
  production)
    export ENVIRONMENT=production
    ;;
  *)
    echo "${red}Unknown environment: $env${reset}"
    return 1
    ;;
  esac
}

function db-container-prefix() {
  # Map environment name to Docker container prefix
  local env="$1"
  case "$env" in
  development) echo "icb-dev" ;;
  testing) echo "icb-test" ;;
  production) echo "icb-prod" ;;
  esac
}

function db-seed() {
  local env="$1"
  shift
  cd "$ICHRISBIRCH_HOME" || exit

  if [[ "$env" == "production" ]]; then
    echo "${red}Seeding production is not allowed${reset}"
    return 1
  fi

  db-env-vars "$env" || return 1
  # shellcheck disable=1091
  source "$ICHRISBIRCH_HOME/.venv/bin/activate"
  echo "${blue}Seeding ${env} database...${reset}"
  uv run python -m scripts.seed --env "$env" "$@"
}

function db-init() {
  local env="$1"
  cd "$ICHRISBIRCH_HOME" || exit

  local prefix
  prefix=$(db-container-prefix "$env")
  local container="${prefix}-api"

  echo "${blue}Initializing ${env} database via ${container}...${reset}"
  docker exec "$container" python -m ichrisbirch.database.initialization --env "$env"
}

function db-reset() {
  local env="$1"
  cd "$ICHRISBIRCH_HOME" || exit

  if [[ "$env" != "testing" ]]; then
    echo "${red}Database reset is only allowed for testing environment${reset}"
    return 1
  fi

  # reset_test_database.py enforces its own safety checks (testing, localhost, 5434)
  # shellcheck disable=1091
  source "$ICHRISBIRCH_HOME/.venv/bin/activate"
  echo "${blue}Resetting testing database...${reset}"
  ENVIRONMENT=testing uv run python -m ichrisbirch.database.reset_test_database
}

function env-db() {
  local env="$1"
  local subcmd="$2"
  shift 2

  case "$subcmd" in
  seed)
    db-seed "$env" "$@"
    ;;
  init)
    db-init "$env"
    ;;
  reset)
    db-reset "$env"
    ;;
  "")
    db-usage
    ;;
  *)
    echo "${red}Unknown db command: $subcmd${reset}"
    db-usage
    ;;
  esac
}

function db-usage() {
  echo "${green}Database Commands:${reset}"
  echo "  ${blue}db seed [options]${reset}  - Seed with generated data"
  echo "  ${blue}db init${reset}            - Initialize database (schemas + migrations + users)"
  echo "  ${blue}db reset${reset}           - Drop + recreate everything (testing only)"
  echo ""
  echo "${yellow}Database Lifecycle:${reset}"
  echo "  ${green}init${reset}   — First-time setup: create schemas, run migrations, insert users"
  echo "  ${green}reset${reset}  — Nuclear option: drop all tables + init from scratch (use when migrations change)"
  echo "  Truncation between test runs is handled automatically by pytest fixtures."
  echo ""
  echo "${yellow}Seed Options:${reset}"
  echo "  --scale N          Scale multiplier for record counts (default: 1)"
  echo "  --dry-run          Discover and generate without inserting"
  echo "  --only MODEL ...   Seed only these model names"
  echo "  --seed N           Faker random seed (default: 42)"
  echo ""
  echo "${yellow}Examples:${reset}"
  echo "  icb dev db seed --scale 3 --dry-run"
  echo "  icb testing db reset"
}
