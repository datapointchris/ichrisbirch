# Production environment
function load-prod-env() {
  cd "$ICHRISBIRCH_HOME" || exit
  if ! command -v sops &>/dev/null; then
    echo "${red}sops not found. Install from https://github.com/getsops/sops/releases${reset}"
    return 1
  fi
  if [[ ! -f "secrets/secrets.prod.enc.env" ]]; then
    echo "${red}secrets/secrets.prod.enc.env not found${reset}"
    return 1
  fi
  echo "${yellow}Loading production secrets via SOPS...${reset}"
  set -a
  # shellcheck disable=SC1090
  source <(sops decrypt secrets/secrets.prod.enc.env)
  set +a
  export DOMAIN="${DOMAIN:-ichrisbirch.com}"
}

function prod-start() {
  cd "$ICHRISBIRCH_HOME" || exit
  load-prod-env || return 1

  local color
  color=$(get_active_color)

  if [[ -n "$color" ]]; then
    echo "Starting ${magenta}PRODUCTION${reset} (blue/green: ${cyan}${color}${reset})"
    $COMPOSE_INFRA up -d
    compose_app "$color" up -d
  else
    echo "Starting ${magenta}PRODUCTION${reset} (legacy single-compose)"
    $COMPOSE_PROD up -d
  fi

  echo ""
  echo "  ${green}APP${reset}:  ${cyan}${PROD_APP_URL}${reset}"
  echo "  ${green}API${reset}:  ${cyan}${PROD_API_URL}${reset}"
  echo "  ${green}CHAT${reset}: ${cyan}${PROD_CHAT_URL}${reset}"
}

function prod-stop() {
  cd "$ICHRISBIRCH_HOME" || exit
  load-prod-env || return 1

  local color
