#!/usr/bin/env bash
# shellcheck shell=bash
# shellcheck disable=SC2034

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ICHRISBIRCH_HOME="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

# URLs for each environment
DEV_API_URL="https://api.docker.localhost"
DEV_APP_URL="https://app.docker.localhost"
DEV_CHAT_URL="https://chat.docker.localhost"
DEV_DASHBOARD_URL="https://dashboard.docker.localhost"
DEV_API_PORT="http://localhost:8000"
DEV_CHAT_PORT="http://localhost:8505"

TEST_API_URL="https://api.test.localhost:8443"
TEST_APP_URL="https://app.test.localhost:8443"
TEST_CHAT_URL="https://chat.test.localhost:8443"
TEST_DASHBOARD_URL="https://dashboard.test.localhost:8443"
TEST_API_PORT="http://localhost:8001"
TEST_CHAT_PORT="http://localhost:8507"

PROD_DOMAIN="${DOMAIN:-ichrisbirch.com}"
PROD_API_URL="https://api.${PROD_DOMAIN}"
PROD_APP_URL="https://${PROD_DOMAIN}"
PROD_CHAT_URL="https://chat.${PROD_DOMAIN}"

# Docker compose commands
COMPOSE_DEV="docker compose --project-name icb-dev -f docker-compose.yml -f docker-compose.dev.yml"
COMPOSE_TEST="docker compose --project-name icb-test -f docker-compose.yml -f docker-compose.test.yml"
COMPOSE_PROD="docker compose --project-name icb-prod -f docker-compose.yml"

# Blue/green deployment compose commands
COMPOSE_INFRA="docker compose --project-name icb-infra -f docker-compose.infra.yml"
BLUEGREEN_STATE_FILE="/var/lib/ichrisbirch/bluegreen-state"

compose_app() {
  local color="$1"
  shift
  DEPLOY_COLOR="$color" docker compose --project-name "icb-${color}" -f docker-compose.app.yml "$@"
}

get_active_color() {
  if [[ -f "$BLUEGREEN_STATE_FILE" ]]; then
    cat "$BLUEGREEN_STATE_FILE"
  else
    echo ""
  fi
}

# Script paths
HEALTH_CHECK_SCRIPT="$ICHRISBIRCH_HOME/cli/health-check.sh"
SSL_MANAGER_SCRIPT="$ICHRISBIRCH_HOME/deploy-containers/traefik/scripts/ssl-manager.sh"

# Colors
red=$(tput setaf 1)
green=$(tput setaf 2)
yellow=$(tput setaf 3)
blue=$(tput setaf 4)
magenta=$(tput setaf 5)
cyan=$(tput setaf 6)
white=$(tput setaf 7)
gray=$(tput setaf 8)
bright_red=$(tput setaf 9)
bright_green=$(tput setaf 10)
bright_yellow=$(tput setaf 11)
bright_blue=$(tput setaf 12)
bright_magenta=$(tput setaf 13)
bright_cyan=$(tput setaf 14)
orange=$(tput setaf 208)
reset=$(tput sgr0)

# Source command modules
# shellcheck source=cli/stats
source "$ICHRISBIRCH_HOME/cli/stats"
# shellcheck source=cli/db
source "$ICHRISBIRCH_HOME/cli/db"

function dev-credentials() {
  local env_file="$ICHRISBIRCH_HOME/.env"
  if [ -f "$env_file" ]; then
    local admin_email admin_pass regular_email regular_pass
    admin_email=$(grep -E '^USERS_DEFAULT_ADMIN_USER_EMAIL=' "$env_file" | cut -d= -f2 | tr -d '"')
    admin_pass=$(grep -E '^USERS_DEFAULT_ADMIN_USER_PASSWORD=' "$env_file" | cut -d= -f2 | tr -d '"')
    regular_email=$(grep -E '^USERS_DEFAULT_REGULAR_USER_EMAIL=' "$env_file" | cut -d= -f2 | tr -d '"')
    regular_pass=$(grep -E '^USERS_DEFAULT_REGULAR_USER_PASSWORD=' "$env_file" | cut -d= -f2 | tr -d '"')

    echo ""
    echo "${yellow}Dev Credentials:${reset}"
    echo "  ${cyan}Regular${reset}: ${regular_email} / ${regular_pass}"
    echo "  ${green}Admin${reset}:   ${admin_email} / ${admin_pass}"
  else
    echo ""
    echo "${yellow}Dev Credentials:${reset} ${red}.env file not found${reset}"
  fi
}

function colored-logs() {
  local RED_REDIS="${red}redis${reset}"
  local GREEN_POSTGRES="${green}postgres${reset}"
  local BRIGHT_GREEN_API="${bright_green}api${reset}"
  local BRIGHT_BLUE_VUE="${bright_blue}vue${reset}"
  local ORANGE_CHAT="${orange}chat${reset}"
  local YELLOW_SCHEDULER="${yellow}scheduler${reset}"
  local CYAN_TRAEFIK="${cyan}traefik${reset}"

  sed \
    -e 's/icb-//g' \
    -e 's/dev-//g' \
    -e 's/test-//g' \
    -e 's/prod-//g' \
    -e 's/blue-//g' \
    -e 's/green-//g' \
    -e 's/infra-//g' \
    -e 's/^api[ ]*|/'"${BRIGHT_GREEN_API}"' |/' \
    -e 's/^vue[ ]*|/'"${BRIGHT_BLUE_VUE}"' |/' \
    -e 's/^redis[ ]*|/'"${RED_REDIS}"' |/' \
    -e 's/^postgres[ ]*|/'"${GREEN_POSTGRES}"' |/' \
    -e 's/^chat[ ]*|/'"${ORANGE_CHAT}"' |/' \
    -e 's/^scheduler[ ]*|/'"${YELLOW_SCHEDULER}"' |/' \
    -e 's/^traefik[ ]*|/'"${CYAN_TRAEFIK}"' |/'
}

function colored-status() {
  local GREEN_RUNNING="${green}running${reset}"
  local RED_EXITED="${red}exited${reset}"
  local YELLOW_RESTARTING="${yellow}restarting${reset}"
  local BLUE_PAUSED="${blue}paused${reset}"
  local MAGENTA_DEAD="${magenta}dead${reset}"
  local CYAN_CREATED="${cyan}created${reset}"
  local YELLOW_UNHEALTHY="${yellow}unhealthy${reset}"
  local GREEN_HEALTHY="${green}healthy${reset}"

  awk -v running="$GREEN_RUNNING" \
    -v exited="$RED_EXITED" \
    -v restarting="$YELLOW_RESTARTING" \
    -v paused="$BLUE_PAUSED" \
    -v dead="$MAGENTA_DEAD" \
    -v created="$CYAN_CREATED" \
    -v unhealthy="$YELLOW_UNHEALTHY" \
    -v healthy="$GREEN_HEALTHY" '
    {
        gsub(/icb-/, "");
        gsub(/blue-/, "");
        gsub(/green-/, "");
        gsub(/infra-/, "");
        gsub(/running/, running);
        gsub(/exited/, exited);
        gsub(/restarting/, restarting);
        gsub(/paused/, paused);
        gsub(/dead/, dead);
        gsub(/created/, created);
        gsub(/unhealthy/, unhealthy);
        gsub(/healthy/, healthy);
        print $0;
    }'
}

function install() {
  local target="$HOME/.local/bin/icb"
  mkdir -p "$(dirname "$target")"
  ln -sf "$ICHRISBIRCH_HOME/cli/icb" "$target"
  echo "${green}Installed:${reset} $target -> $ICHRISBIRCH_HOME/cli/icb"
}

function wait-for-healthy() {
  local container="$1"
  local max_wait="${2:-60}"
  local interval="${3:-5}"
  local waited=0

  while [[ $waited -lt $max_wait ]]; do
    local health
    health=$(docker inspect --format='{{.State.Health.Status}}' "$container" 2>/dev/null || echo "missing")
    if [[ "$health" == "healthy" ]]; then
      echo "${green}${container} healthy after ${waited}s${reset}"
      return 0
    fi
    sleep "$interval"
    waited=$((waited + interval))
  done

  echo "${yellow}${container} not healthy after ${max_wait}s (continuing anyway)${reset}"
  return 1
}

function env-docker-config() {
  local env="$1"
  shift
  local service="$1"
  local compose_cmd

  case "$env" in
    development) compose_cmd="$COMPOSE_DEV" ;;
    testing) compose_cmd="$COMPOSE_TEST" ;;
    production) compose_cmd="$COMPOSE_PROD" ;;
    *) echo "${red}Unknown environment: $env${reset}"; return 1 ;;
  esac

  cd "$ICHRISBIRCH_HOME" || return 1

  if [[ -z "$service" ]]; then
    $compose_cmd config
  else
    if ! $compose_cmd config --services 2>/dev/null | grep -q "^${service}$"; then
      echo "${red}Unknown service: $service${reset}"
      echo "Available: $($compose_cmd config --services 2>/dev/null | tr '\n' ' ')"
      return 1
    fi
    $compose_cmd config 2>/dev/null | yq -y ".services.\"$service\""
  fi
}

function ssl-manager() {
  local action="${1:-info}"
  local environment="${2:-all}"
  cd "$ICHRISBIRCH_HOME" || exit

  if [ -x "$SSL_MANAGER_SCRIPT" ]; then
    "$SSL_MANAGER_SCRIPT" "$action" "$environment"
  else
    echo "${red}SSL manager script not found: $SSL_MANAGER_SCRIPT${reset}"
    return 1
  fi
}

# Development environment
function dev-start() {
  cd "$ICHRISBIRCH_HOME" || exit
  echo "Starting ${blue}DEV${reset} environment"
  $COMPOSE_DEV up -d

  echo "Waiting for API container..."
  wait-for-healthy icb-dev-api 30 || true
  docker exec icb-dev-api python -m ichrisbirch.database.initialization --env development 2>/dev/null || true

  echo ""
  echo "Development environment started:"
  echo "  ${green}API${reset}:       ${cyan}${DEV_API_URL}${reset}"
  echo "  ${green}APP${reset}:       ${cyan}${DEV_APP_URL}${reset}"
  echo "  ${green}CHAT${reset}:      ${cyan}${DEV_CHAT_URL}${reset}"
  echo "  ${green}DASHBOARD${reset}: ${cyan}${DEV_DASHBOARD_URL}${reset} (user: dev, pass: devpass)"
  echo ""
  echo "Direct ports (bypass Traefik):"
  echo "  ${green}API${reset}:  ${cyan}${DEV_API_PORT}${reset}"
  echo "  ${green}CHAT${reset}: ${cyan}${DEV_CHAT_PORT}${reset}"
  echo "  ${green}PostgreSQL${reset}: ${cyan}localhost:5432${reset}"
  echo "  ${green}Redis${reset}: ${cyan}localhost:6379${reset}"
  dev-credentials
}

function dev-stop() {
  cd "$ICHRISBIRCH_HOME" || exit
  echo "Stopping ${blue}DEV${reset} environment"
  $COMPOSE_DEV down
}

function dev-restart() {
  cd "$ICHRISBIRCH_HOME" || exit
  echo "Restarting ${blue}DEV${reset} environment"
  $COMPOSE_DEV up -d
  dev-credentials
}

function dev-rebuild() {
  cd "$ICHRISBIRCH_HOME" || exit

  local rebuild_all=false
  local wipe_volumes=false
  for arg in "$@"; do
    case "$arg" in
      --all) rebuild_all=true ;;
      --volumes) wipe_volumes=true ;;
      *) echo "${red}Unknown flag: $arg${reset}"; echo "Valid flags: --all, --volumes"; return 1 ;;
    esac
  done

  if [[ "$wipe_volumes" == true ]]; then
    echo "Wiping volumes for ${blue}DEV${reset} environment (${yellow}--volumes${reset})"
    $COMPOSE_DEV down --volumes
  elif [[ "$rebuild_all" == true ]]; then
    echo "Full rebuild of ${blue}DEV${reset} environment (${yellow}--all${reset})"
    $COMPOSE_DEV down
  fi

  if [[ "$rebuild_all" == true ]]; then
    echo "Building all images..."
    $COMPOSE_DEV build
    echo "Starting all services..."
    $COMPOSE_DEV up -d
  elif [[ "$wipe_volumes" == true ]]; then
    # Volumes wiped, everything is down. Rebuild api only and start everything back up.
    echo "Building app image..."
    $COMPOSE_DEV build api
    echo "Starting all services (volumes were wiped)..."
    $COMPOSE_DEV up -d
  else
    echo "Rebuilding ${blue}DEV${reset} app services (use ${cyan}--all${reset} for infra, ${cyan}--volumes${reset} to wipe volumes)"
    echo "Building app image..."
    $COMPOSE_DEV build api
    echo "Recreating app services..."
    $COMPOSE_DEV up -d --force-recreate api chat scheduler vue
  fi

  echo "Waiting for API container..."
  wait-for-healthy icb-dev-api 60
  echo "Initializing database..."
  docker exec icb-dev-api python -m ichrisbirch.database.initialization --env development
  echo "Seeding database..."
  db-seed development
  echo "${green}DEV environment rebuilt, initialized, and seeded${reset}"
  dev-credentials
}

function dev-logs() {
  cd "$ICHRISBIRCH_HOME" || exit
