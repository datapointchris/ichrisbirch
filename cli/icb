function prod-smoke() {
  echo "Running smoke tests on ${magenta}PRODUCTION${reset} environment"
  if [[ -z "${ICHRISBIRCH_API_KEY:-}" ]]; then
    echo "${red}Error: ICHRISBIRCH_API_KEY not set${reset}"
    echo "Set it to a personal API key (icb_...) for an admin user"
    return 1
  fi
  local response
  response=$(curl --silent -X POST "$PROD_API_URL/admin/smoke-tests/" \
    -H "Authorization: Bearer $ICHRISBIRCH_API_KEY" 2>/dev/null)
  if [[ -z "$response" ]]; then
    echo "${red}Error: Could not connect to $PROD_API_URL${reset}"
    return 1
  fi
  printf "  %-6s %5s  %-40s %-30s %8s  %s\n" "RESULT" "CODE" "PATH" "NAME" "TIME" "ERROR"
  printf "  %s\n" "$(printf '%0.sâ”€' {1..100})"
  echo "$response" | jq -r '.results[] | (if .passed then "  \u001b[32m  PASS\u001b[0m" else "  \u001b[31m  FAIL\u001b[0m" end) + " " + ((.status_code // 0 | tostring) | " " * (5 - length) + .) + "  " + (.path + " " * 40)[:40] + " " + (.name + " " * 30)[:30] + " " + ((.response_time_ms | tostring) + "ms" | " " * (8 - length) + .) + "  " + (.error // "")'
  echo ""
  echo "$response" | jq '{total: .total, passed: .passed, failed: .failed, duration_ms: .duration_ms, all_passed: .all_passed}'
}

function prod-build-test() {
  # Test that production Docker build works correctly.
  # This catches issues that only manifest in production builds
