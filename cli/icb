function prod-deploy-status() {
  cd "$ICHRISBIRCH_HOME" || exit

  local color
  color=$(get_active_color)

  echo "${magenta}PRODUCTION${reset} deployment status:"
  echo ""

  if [[ -z "$color" ]]; then
    echo "  ${yellow}Blue/green not initialized${reset} (using legacy single-compose)"
    echo ""
    return 0
  fi

  echo "  ${green}Active color${reset}: ${cyan}${color}${reset}"
  echo ""

  echo "  ${green}Infrastructure:${reset}"
  docker ps --format '    {{.Names}}: {{.Status}}' --filter "name=icb-infra" 2>/dev/null || echo "    not running"
  echo ""

  echo "  ${green}App (${color}):${reset}"
  docker ps --format '    {{.Names}}: {{.Status}}' --filter "name=icb-${color}" 2>/dev/null || echo "    not running"
  echo ""

  # Check if the other color has any containers (shouldn't normally)
  local other_color
  if [[ "$color" == "blue" ]]; then other_color="green"; else other_color="blue"; fi
  local other_containers
  other_containers=$(docker ps --format '{{.Names}}' --filter "name=icb-${other_color}" 2>/dev/null)
  if [[ -n "$other_containers" ]]; then
    echo "  ${yellow}Standby (${other_color}) â€” still running:${reset}"
    docker ps --format '    {{.Names}}: {{.Status}}' --filter "name=icb-${other_color}" 2>/dev/null
    echo ""
  fi

  echo "  ${green}Routing:${reset}"
  local services_file="$ICHRISBIRCH_HOME/deploy-containers/traefik/dynamic/prod/services.yml"
  if [[ -f "$services_file" ]]; then
    local routing_color
    routing_color=$(grep -o 'icb-\(blue\|green\)-api' "$services_file" | head -1 | sed 's/icb-\(.*\)-api/\1/')
    echo "    Traefik routing â†’ ${cyan}${routing_color}${reset}"
    if [[ "$routing_color" != "$color" ]]; then
      echo "    ${red}WARNING: services.yml points to ${routing_color} but state says ${color}!${reset}"
    fi
  else
    echo "    ${red}services.yml not found${reset}"
  fi
}

function prod-rollback() {
  cd "$ICHRISBIRCH_HOME" || exit
  load-prod-env || return 1

  local current_color
  current_color=$(get_active_color)

  if [[ -z "$current_color" ]]; then
    echo "${red}Blue/green not initialized â€” nothing to roll back${reset}"
    return 1
  fi

  local previous_color
  if [[ "$current_color" == "blue" ]]; then previous_color="green"; else previous_color="blue"; fi

  echo "${yellow}Rolling back:${reset} ${current_color} â†’ ${previous_color}"
  echo ""

  # Check if previous color containers are still running
  local prev_running
  prev_running=$(docker ps --format '{{.Names}}' --filter "name=icb-${previous_color}-api" 2>/dev/null)

  if [[ -z "$prev_running" ]]; then
    echo "Previous containers (${previous_color}) not running. Starting them..."
    compose_app "$previous_color" up -d

    if ! wait-for-healthy "icb-${previous_color}-api" 90; then
      echo "${red}Previous containers did not become healthy. Rollback aborted.${reset}"
      return 1
    fi
  else
    echo "Previous containers (${previous_color}) still running"
  fi

  # Switch routing by regenerating services.yml
  local services_file="$ICHRISBIRCH_HOME/deploy-containers/traefik/dynamic/prod/services.yml"
  local services_tmp="${services_file}.tmp"

  cat > "$services_tmp" <<EOF
# Generated by CLI rollback â€” DO NOT EDIT
# Active color: ${previous_color}

http:
  services:
    api:
      loadBalancer:
        servers:
          - url: "http://icb-${previous_color}-api:8000"
    vue:
      loadBalancer:
        servers:
          - url: "http://icb-${previous_color}-vue:80"
    chat:
      loadBalancer:
        servers:
          - url: "http://icb-${previous_color}-chat:8505"
        sticky:
          cookie:
            name: chat-prod-session
EOF
  mv "$services_tmp" "$services_file"

  echo "$previous_color" > "$BLUEGREEN_STATE_FILE"

  echo ""
  echo "${green}Rolled back to ${previous_color}${reset}"
  echo "Traefik will pick up the change within 1-2 seconds."
  echo ""
  echo "The ${current_color} containers are still running. Stop them with:"
  echo "  ${cyan}DEPLOY_COLOR=${current_color} docker compose --project-name icb-${current_color} -f docker-compose.app.yml down${reset}"
}

function prod-logs() {
  cd "$ICHRISBIRCH_HOME" || exit
  local log_dir="/srv/ichrisbirch/logs"

  case "$1" in
  deploy)
    echo "${magenta}PRODUCTION${reset} deployment logs:"
    echo ""
    echo "${cyan}Log directory:${reset} $log_dir"
    echo ""
    if [ -f "$log_dir/deploy.log" ]; then
      echo "${yellow}=== Recent deployment events (deploy.log) ===${reset}"
      tail -50 "$log_dir/deploy.log"
    else
      echo "${red}deploy.log not found${reset}"
    fi
    ;;
  build)
    echo "${magenta}PRODUCTION${reset} build logs:"
    echo ""
    echo "${cyan}Available build logs:${reset}"
    # shellcheck disable=SC2012
    ls -lt "$log_dir"/build-*.log 2>/dev/null | head -5 || echo "  No build logs found"
    echo ""
    local latest_log
    # shellcheck disable=SC2012
    latest_log=$(ls -t "$log_dir"/build-*.log 2>/dev/null | head -1)
    if [ -n "$latest_log" ]; then
      echo "${yellow}=== Most recent build log: $(basename "$latest_log") ===${reset}"
      tail -100 "$latest_log"
    fi
    ;;
  *)
    load-prod-env || return 1
    local color
    color=$(get_active_color)
    if [[ -n "$color" ]]; then
      echo "Viewing ${magenta}PRODUCTION${reset} logs (${cyan}${color}${reset}) (Ctrl+C to exit)"
      echo ""
      while true; do
        compose_app "$color" logs --follow --tail=50 "$@" 2>/dev/null | colored-logs
        sleep 2
      done
    else
      echo "Viewing ${magenta}PRODUCTION${reset} logs (Ctrl+C to exit)"
      echo ""
      while true; do
        $COMPOSE_PROD logs --follow --tail=50 "$@" 2>/dev/null | colored-logs
        sleep 2
      done
    fi
    ;;
  esac
}

