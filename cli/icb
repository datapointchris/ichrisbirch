function dev-smoke() {
  echo "Running smoke tests on ${blue}DEV${reset} environment"
  local response
  response=$(curl --silent -X POST "$DEV_API_URL/admin/smoke-tests/" \
    -H "Remote-User: user@icb.com" \
    -H "Remote-Email: user@icb.com" \
    -k 2>/dev/null)
  if [[ -z "$response" ]]; then
    echo "${red}Error: Could not connect to $DEV_API_URL${reset}"
    return 1
  fi
  printf "  %-6s %5s  %-40s %-30s %8s  %s\n" "RESULT" "CODE" "PATH" "NAME" "TIME" "ERROR"
  printf "  %s\n" "$(printf '%0.sâ”€' {1..100})"
  echo "$response" | jq -r '.results[] | (if .passed then "  \u001b[32m  PASS\u001b[0m" else "  \u001b[31m  FAIL\u001b[0m" end) + " " + ((.status_code // 0 | tostring) | " " * (5 - length) + .) + "  " + (.path + " " * 40)[:40] + " " + (.name + " " * 30)[:30] + " " + ((.response_time_ms | tostring) + "ms" | " " * (8 - length) + .) + "  " + (.error // "")'
  echo ""
  echo "$response" | jq '{total: .total, passed: .passed, failed: .failed, duration_ms: .duration_ms, all_passed: .all_passed}'
}

# Test environment
function test-run() {
  cd "$ICHRISBIRCH_HOME" || exit
  # shellcheck disable=1091
  source "$ICHRISBIRCH_HOME/.venv/bin/activate"
  export ENVIRONMENT=testing

  # Check if containers are already running and healthy
  local containers_ready=false
  if $COMPOSE_TEST ps --status running -q 2>/dev/null | grep -q .; then
    echo "${blue}Test containers already running, checking health...${reset}"
    if $COMPOSE_TEST ps | grep -q "healthy"; then
      containers_ready=true
      echo "${green}Containers healthy, reusing them${reset}"
    else
      echo "${yellow}Containers unhealthy, restarting...${reset}"
      $COMPOSE_TEST down --volumes 2>/dev/null || true
    fi
  fi

  if [ "$containers_ready" = false ]; then
    echo "${blue}Starting test containers...${reset}"
    $COMPOSE_TEST up -d
    echo "Waiting for API container..."
    wait-for-healthy icb-test-api 60 || true
  fi

  # Database truncation is handled by pytest's truncate_tables fixture.
  # Do NOT truncate here â€” double-truncate causes user count mismatches and FK violations.

  # Run pytest
  echo ""
  echo "${green}Running tests...${reset}"
  echo ""
  local test_exit_code=0
  local -a json_report_flags=(--json-report --json-report-file=/tmp/ichrisbirch-pytest-report.json --json-report-indent=2)
  if [ $# -eq 0 ]; then
    uv run pytest "${json_report_flags[@]}" 2>&1 | tee /tmp/ichrisbirch-pytest-output.log
    test_exit_code=${PIPESTATUS[0]}
  else
    uv run pytest "${json_report_flags[@]}" "$@" 2>&1 | tee /tmp/ichrisbirch-pytest-output.log
    test_exit_code=${PIPESTATUS[0]}
  fi

  # Always leave containers running for fast iteration
  echo ""
  echo "${cyan}Containers left running for fast iteration.${reset}"
  echo "Stop them with: ${blue}icb testing stop${reset}"

  return "$test_exit_code"
}

function test-usage() {
  echo "${green}Test commands:${reset}"
  echo "  ${blue}test run [path] [args]${reset}  Run pytest (reuses containers for fast iteration)"
  echo ""
  echo "Containers are left running after tests for fast re-runs."
  echo "Stop them with: ${blue}icb testing stop${reset}"
