:80 {
    # Everything — static files with SPA fallback
    handle {
        root * /srv
        try_files {path} /index.html
        file_server

        # Prevent caching of index.html (SPA entry point)
        @html path /index.html
        header @html Cache-Control "no-cache, no-store, must-revalidate"
        header @html Pragma "no-cache"
        header @html Expires "0"

        # Cache static assets with content hashes (1 year)
        @static path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2
        header @static Cache-Control "public, max-age=31536000, immutable"
    }

    encode gzip
}
